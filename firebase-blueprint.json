{
  "entities": {
    "enrollment": {
      "title": "Enrollment",
      "description": "Represents a user's registration for a course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "completed"] },
        "enrolledAt": { "type": "string", "format": "date-time" },
        "progress": { "type": "number" },
        "completedLessons": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "courseId", "status", "enrolledAt"]
    },
    "lessonProgress": {
      "title": "Lesson Progress",
      "description": "Tracks completion of a specific lesson by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "lessonId": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "courseId", "lessonId", "completedAt"]
    }
  },
  "firestore": {
    "/enrollments/{enrollmentId}": {
      "schema": "enrollment",
      "description": "Course enrollment records"
    },
    "/progress/{progressId}": {
      "schema": "lessonProgress",
      "description": "User lesson completion tracking"
    }
  }
}
